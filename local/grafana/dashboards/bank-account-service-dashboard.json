{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "Business context: demand for account reads; useful during onboarding growth, releases, and incidents.",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(bank_account_service_http_requests_total[5m]))",
          "legendFormat": "request rate"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Business context: customer-impacting failures on account reads should trigger investigation before trust is affected.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(bank_account_service_http_request_errors_total[5m])) / clamp_min(sum(rate(bank_account_service_http_requests_total[5m])), 1)",
          "legendFormat": "5xx error ratio"
        }
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Business context: p95 catches slow account reads that averages can hide in banking workflows.",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(bank_account_service_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "title": "P95 Latency",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 40,
  "tags": [
    "bank",
    "account-service"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Bank Account Service",
  "uid": "bank-account-service"
}
